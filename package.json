    "firebase-admin": "^12.7.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "firebase-tools": "^15.16.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.16"
  }
}
